[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
requires-python = ">={{ python_min_version }}"
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
{% if license == "MIT" %}
license = { text = "MIT" }
{% else %}
license = { text = "Proprietary" }
{% endif %}
dependencies = [
  "pydantic-settings>=2.6",
  "rich>=13.9",
{% if project_type in ["cli", "automation"] %}
  "typer>=0.12",
{% endif %}
{% if project_type == "api" %}
  "fastapi>=0.110",
  "uvicorn[standard]>=0.29",
{% endif %}
{% if project_type in ["data", "ml"] %}
  "numpy>=1.26",
  "pandas>=2.2",
{% endif %}
{% if project_type == "data" %}
  "pyarrow>=15.0",
{% endif %}
{% if project_type == "ml" %}
  "scikit-learn>=1.5",
{% endif %}
{% if include_http_client %}
  "httpx>=0.27",
{% endif %}
{% if include_database %}
  "sqlalchemy>=2.0",
  "alembic>=1.13",
{% endif %}
]

{% if project_type == "cli" %}
[project.scripts]
{{ project_slug }} = "{{ package_name }}.cli:app"
{% elif project_type == "automation" %}
[project.scripts]
{{ project_slug }} = "{{ package_name }}.runner:app"
{% endif %}

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[dependency-groups]
dev = [
  "pre-commit>=3.0",
]
lint = [
  "ruff>=0.8",
  "mypy>=1.13",
]
test = [
  "pytest>=8.3",
  "pytest-cov>=5.0",
]
{% if include_notebooks %}
notebooks = [
  "ipykernel>=6.29",
  "jupyterlab>=4.2",
]
{% endif %}
{% if include_docs %}
docs = [
  "mkdocs>=1.6",
  "mkdocs-material>=9.5",
  "mkdocstrings[python]>=0.26",
]
{% endif %}

[tool.pytest.ini_options]
addopts = "-q"
testpaths = ["tests"]
pythonpath = ["src"]

[tool.ruff]
line-length = 88
target-version = "py{{ python_min_version | replace('.', '') }}"
fix = true
force-exclude = true

[tool.ruff.lint]
select = ["E", "F", "I", "B", "UP"]
