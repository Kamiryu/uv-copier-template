"""Automation runner for {{ project_name }}."""

from typing import Annotated

import typer

from .common.logging import configure_logging
from .settings import settings

app = typer.Typer(help="Automation tasks for {{ project_name }}.")


@app.callback()
def main(
    log_level: Annotated[
        str,
        typer.Option(help="Logging level to use for automation tasks."),
    ] = settings.log_level,
) -> None:
    """Configure shared runner options."""

    configure_logging(log_level, settings.log_file)


@app.command()
def run() -> None:
    """Run the default automation task."""

    typer.echo("No automation task configured yet.")
